{
  "compilerOptions": {
    "target": "ES2019",
    "module": "ES2020",
    "moduleResolution": "bundler",

    "lib": ["es2020", "dom"],

    "experimentalDecorators": true,
    "useDefineForClassFields": false,

    "strict": true,
    "noImplicitAny": false,

    "outDir": "./",
    "rootDir": "./",

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  },

  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}